key="artists" value="アズサワ コハネ"/><amll:meta key="artists" value="Azusawa Kohane"/><amll:meta key="artists" value="小豆沢心羽"/><amll:meta key="artists" value="小豆澤心羽"/><amll:meta key="artists" value="小豆泽心羽"/><amll:meta key="artists" value="아즈사와 코하네"/><amll:meta key="artists" value="白石 杏"/><amll:meta key="artists" value="白石杏"/><amll:meta key="artists" value="しらいし あん"/><amll:meta key="artists" value="シライシ アン"/><amll:meta key="artists" value="Shiraishi An"/><amll:meta key="artists" value="시라이시"/><amll:meta key="artists" value="東雲 彰人"/><amll:meta key="artists" value="東雲彰人"/><amll:meta key="artists" value="しののめ あきと"/><amll:meta key="artists" value="シノノメ アキト"/><amll:meta key="artists" value="Shinonome Akito"/><amll:meta key="artists" value="东云彰人"/><amll:meta key="artists" value="시노노메 아키토"/><amll:meta key="artists" value="青柳 冬弥"/><amll:meta key="artists" value="青柳冬弥"/><amll:meta key="artists" value="あおやぎ とうや"/><amll:meta key="artists" value="アオヤギ トウヤ"/><amll:meta key="artists" value="Aoyagi Touya"/><amll:meta key="artists" value="青柳冬彌"/><amll:meta key="artists" value="아오야기 토우야"/><amll:meta key="artists" value="Vivid BAD SQUAD"/><amll:meta key="artists" value="ビビッドバッドスクワッド"/><amll:meta key="artists" value="Bibiddo Baddo Sukuwaddo"/><amll:meta key="artists" value="炫狂小队"/><amll:meta key="album" value="RAD DOGS/シネマ"/><amll:meta key="album" value="RAD DOGS/シネマ - Single"/><amll:meta key="album" value="RAD DOGS / Cinema - Single"/><amll:meta key="ncmMusicId" value="1894065143"/><amll:meta key="qqMusicId" value="002ZNzRr13jUsQ"/><amll:meta key="qqMusicId" value="332293151"/><amll:meta key="spotifyId" value="6NU68pCIE8srz6YbOfBe34"/><amll:meta key="appleMusicId" value="1594806616"/><amll:meta key="isrc" value="JPX302136180"/><amll:meta key="Composer" value="Hachioji P"/><amll:meta key="Lyrics" value="q*Left"/><amll:meta key="ttmlAuthorGithub" value="68000793"/><amll:meta key="ttmlAuthorGithubLogin" value="ranhengzhang"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><translations><translation type="subtitle" xml:lang="en"><text for="L1">Taking off my headphones, I walk alone in the town by myself</text><text for="L2">Did I get lost?</text><text for="L3">Did I take the wrong turn? Seems like a place that I don&apos;t recognize</text><text for="L4">My unseen devotion, sympathy that I don&apos;t feel,</text><text for="L5">And all the things that I can&apos;t have</text><text for="L6">What kind of story? Whose story is it?</text><text for="L7">If you don&apos;t have something, you&apos;ll start to want it, isn’t that right?</text><text for="L8">Give me the signal, hold up the mic</text><text for="L9">Right now, that guy&apos;s fluttering along with the tailwind</text><text for="L10">Here comes the chance!</text><text for="L11">Time to dive, hater!</text><text for="L12">Now, I&apos;ve decided to restart for the first time</text><text for="L13">Just saying &quot;I want to be like you&quot; is all you need, right?</text><text for="L14">Not knowing the reason why</text><text for="L15">Not needing the reason why</text><text for="L16">I&apos;m defying against fate&apos;s rules</text><text for="L17">Now, I&apos;ve decided to restart and burst out</text><text for="L18">Just saying &quot;I want to see it&quot; is all you need, right?</text><text for="L19">Let that groovy sound beat</text><text for="L20">Let me hear that heartbeat</text><text for="L21">Since there&apos;s no time to just stand still</text><text for="L23">Ah, ah, mic check!</text><text for="L24">One, two! It&apos;s been all night but you’re unexpectedly composed~</text><text for="L25">I&apos;d say, you&apos;re a real actress, ya know?</text><text for="L26">You&apos;re at the upper part of the society ladder? Then make a statement!</text><text for="L27">The rad and bad underdog</text><text for="L28">Surprised you, huh, dyed you with vivid colors</text><text for="L29">The you who haven&apos;t look up today is</text><text for="L30">A troubled top dog that’s hiding its fighting spirit</text><text for="L31">Give us the signal, hold up the mic</text><text for="L32">Right now, we</text><text for="L33">Are fluttering along</text><text for="L34">With the tailwind</text><text for="L35">Here comes the chance!</text><text for="L36">Time to dive, hater!</text><text for="L37">Now, we&apos;ve decided to restart for the first time</text><text for="L38">Just saying &quot;I want to be like you&quot; is all you need, right?</text><text for="L39">Not knowing the reason why</text><text for="L40">Not needing the reason why</text><text for="L41">We enjoy the joys of immorality</text><text for="L42">Now, we&apos;ve decided to restart and burst out</text><text for="L43">Just saying &quot;I want to see it&quot; is all you need, right?</text><text for="L44">Let that groovy sound beat</text><text for="L45">Let me hear that heartbeat</text><text for="L46">Since there’s no time to just stand still</text><text for="L47">With the tailwind blowing</text><text for="L48">Alright, we keep going forward</text><text for="L49">Without looking back</text></translation><translation type="subtitle" xml:lang="zh-Hans"><text for="L1">摘下耳机 独自走在街头</text><text for="L2">我是否在迷茫？</text><text for="L3">还是已走错 恍如陌生之地</text><text for="L4">看不见的信仰 感受不到共鸣</text><text for="L5">我全都一无所有</text><text for="L6">是谁的故事？ 谁的故事？</text><text for="L7">得不到才更想要 没错吧</text><text for="L8">给我暗号 高举麦克风</text><text for="L9">那家伙此刻 正乘着顺风远去</text><text for="L10">机会已到来</text><text for="L11">纵身一跃吧 黑子们！</text><text for="L12">此刻重启 下定决心开始</text><text for="L13">“想去看” 仅此而已就够了吧</text><text for="L14">才不知道什么理由</text><text for="L15">才不需要什么理由</text><text for="L16">反抗命运 反抗规则</text><text for="L17">此刻重启 下定决心绽放</text><text for="L18">“想看见” 仅此而已就够了吧</text><text for="L19">敲响这动感节拍</text><text for="L20">让我听见你心跳</text><text for="L21">没有时间停下脚步</text><text for="L23">麦克试音</text><text for="L24">一二 整夜也意外从容～</text><text for="L25">说这种话的你 真是个好演员</text><text for="L26">上流阶级？ 那我可有话要说！</text><text for="L27">又酷又坏的弱者</text><text for="L28">被惊到了吧 染上鲜明色彩</text><text for="L29">只往上看 今天的你啊</text><text for="L30">暗藏斗志的 烦恼的胜犬</text><text for="L31">给我暗号 高举麦克风</text><text for="L32">我们此刻</text><text for="L33">乘着顺风</text><text for="L34">飘扬远去</text><text for="L35">机会已到来</text><text for="L36">纵身一跃吧 黑子们！</text><text for="L37">此刻重启 下定决心开始</text><text for="L38">“想去看” 仅此而已就够了吧</text><text for="L39">才不知道什么理由</text><text for="L40">才不需要什么理由</text><text for="L41">品尝这背德的快感</text><text for="L42">此刻重启 下定决心绽放</text><text for="L43">“想看见” 仅此而已就够了吧</text><text for="L44">敲响这动感节拍</text><text for="L45">让我听见你心跳</text><text for="L46">没有时间停下脚步</text><text for="L47">被顺风吹拂着</text><text for="L48">好了 绝不回头</text><text for="L49">向前迈进</text></translation></translations><songwriters><songwriter>Hachioji P</songwriter><songwriter>q*Left</songwriter></songwriters><transliterations><transliteration xml:lang="ja-Latn"><text for="L1"><span begin="30.600" end="30.840" xmlns="http://www.w3.org/ns/ttml">he</span> <span begin="30.840" end="31.070" xmlns="http://www.w3.org/ns/ttml">d</span><span begin="31.070" end="31.220" xmlns="http://www.w3.org/ns/ttml">do</span> <span begin="31.220" end="31.710" xmlns="http://www.w3.org/ns/ttml">ho n</span> <span begin="31.710" end="32.370" xmlns="http://www.w3.org/ns/ttml">ha zu</span> <span begin="32.370" end="32.800" xmlns="http://www.w3.org/ns/ttml">shi</span> <span begin="32.800" end="33.010" xmlns="http://www.w3.org/ns/ttml">te</span> <span begin="33.180" end="33.560" xmlns="http://www.w3.org/ns/ttml">hi to</span> <span begin="33.560" end="33.750" xmlns="http://www.w3.org/ns/ttml">ri</span> <span begin="33.750" end="34.100" xmlns="http://www.w3.org/ns/ttml">ki</span> <span begin="34.100" end="34.280" xmlns="http://www.w3.org/ns/ttml">ri</span> <span begin="34.280" end="34.710" xmlns="http://www.w3.org/ns/ttml">a ru</span> <span begin="34.710" end="35.040" xmlns="http://www.w3.org/ns/ttml">ku</span> <span begin="35.380" end="35.900" xmlns="http://www.w3.org/ns/ttml">ma chi</span></text><text for="L2"><span begin="36.250" end="36
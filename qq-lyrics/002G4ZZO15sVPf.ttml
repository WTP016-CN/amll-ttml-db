<tt xmlns="http://www.w3.org/ns/ttml" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><ttm:agent type="other" xml:id="v2"/><amll:meta key="musicName" value="野草"/><amll:meta key="musicName" value="Weeds"/><amll:meta key="artists" value="椿乐队"/><amll:meta key="album" value="椿"/><amll:meta key="album" value="Tree Of Heaven"/><amll:meta key="isrc" value="CNUM72400301"/><amll:meta key="ncmMusicId" value="2054517809"/><amll:meta key="qqMusicId" value="002G4ZZO15sVPf"/><amll:meta key="spotifyId" value="2buvlZxOnHQXuqZzgKfgDl"/><amll:meta key="appleMusicId" value="1756177008"/><amll:meta key="ttmlAuthorGithub" value="171883270"/><amll:meta key="ttmlAuthorGithubLogin" value="lansogame"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>黨騫</songwriter><songwriter>海子</songwriter></songwriters></iTunesMetadata></metadata></head><body dur="3:36.378"><div begin="31.428" end="3:36.378"><p begin="31.428" end="32.144" itunes:key="L1" ttm:agent="v1"><span begin="31.428" end="31.679">把</span><span begin="31.679" end="32.144">我</span><span ttm:role="x-translation" xml:lang="zh-CN">把我</span></p><p begin="35.125" end="37.802" itunes:key="L2" ttm:agent="v1"><span begin="35.125" end="35.343">葬</span><span begin="35.343" end="35.590">在</span><span begin="35.590" end="36.307">群</span><span begin="36.307" end="37.048">山</span><span begin="37.048" end="37.476">之</span><span begin="37.476" end="37.802">間</span><span ttm:role="x-translation" xml:lang="zh-CN">葬在群山之间</span></p><p begin="39.461" end="44.518" itunes:key="L3" ttm:agent="v1"><span begin="39.461" end="40.083">我</span><span begin="40.083" end="40.825">看</span><span begin="40.825" end="41.355">到</span><span begin="41.355" end="42.080">鳥</span><span begin="42.080" end="42.356">兒</span><span begin="42.813" end="43.258">在</span><span begin="43.258" end="43.916">飛</span><span begin="43.916" end="44.518">翔</span><span ttm:role="x-translation" xml:lang="zh-CN">我看到鸟儿在飞翔</span></p><p begin="47.017" end="47.704" itunes:key="L4" ttm:agent="v1"><span begin="47.017" end="47.252">睡</span><span begin="47.252" end="47.704">吧</span><span ttm:role="x-translation" xml:lang="zh-CN">睡吧</span></p><p begin="51.180" end="53.449" itunes:key="L5" ttm:agent="v1"><span begin="51.180" end="51.830">孤</span><span begin="51.830" end="52.650">獨</span><span begin="52.650" end="53.123">的</span><span begin="53.123" end="53.449">王</span><span ttm:role="x-translation" xml:lang="zh-CN">孤独的王</span></p><p begin="55.094" end="59.603" itunes:key="L6" ttm:agent="v1"><span begin="55.094" end="55.589">這</span><span begin="55.589" end="55.947">是</span><span begin="56.515" end="56.716">埋</span><span begin="56.716" end="56.980">葬</span><span begin="56.980" end="57.680">詩</span><span begin="57.680" end="58.264">歌</span><span begin="58.264" end="58.450">的</span><span begin="58.450" end="58.952">地</span><span begin="58.952" end="59.603">方</span><span ttm:role="x-translation" xml:lang="zh-CN">这是埋葬诗歌的地方</span></p><p begin="1:02.596" end="1:05.392" itunes:key="L7" ttm:agent="v1"><span begin="1:02.596" end="1:02.880">今</span><span begin="1:02.880" end="1:05.392">夜</span><span ttm:role="x-translation" xml:lang="zh-CN">今夜</span></p><p begin="1:06.261" end="1:11.354" itunes:key="L8" ttm:agent="v1"><span begin="1:06.261" end="1:06.496">我</span><span begin="1:06.496" end="1:06.772">乘</span><span begin="1:06.772" end="1:09.143">風</span><span begin="1:09.691" end="1:10.679">歸</span><span begin="1:10.679" end="1:11.354">去</span><span ttm:role="x-translation" xml:lang="zh-CN">我乘风归去</span></p><p begin="1:18.227" end="1:21.294" itunes:key="L9" ttm:agent="v1"><span begin="1:18.227" end="1:18.470">今</span><span begin="1:18.470" end="1:21.294">夜</span><span ttm:role="x-translation" xml:lang="zh-CN">今夜</span></p><p begin="1:22.398" end="1:26.783" itunes:key="L10" ttm:agent="v1"><span begin="1:22.398" end="1:22.884">歸</span><span begin="1:22.884" end="1:23.127">還</span><span begin="1:23.127" end="1:24.753">於</span><span begin="1:25.326" end="1:25.750">野</span><span begin="1:25.750" end="1:26.289">草</span><span begin="1:26.289" end="1:26.783">地</span><span ttm:role="x-translation" xml:lang="zh-CN">归还于野草地</span></p><p begin="2:36.330" end="2:39.410" itunes:key="L11" ttm:agent="v1"><span begin="2:36.330" end="2:36.561">今</span><span begin="2:36.561" end="2:39.410">夜</span><span ttm:role="x-translation" xml:lang="zh-CN">今夜</span></p><p begin="2:39.931" end="2:44.967" itunes:key="L12" ttm:agent="v1"><span begin="2:39.931" end="2:40.182">我</span><span begin="2:40.182" end="2:40.433">乘</span><span begin="2:40.433" end="2:42.801">風</span><span begin="2:43.287" end="2:44.328">歸</span><span begin="2:44.328" end="2:44.967">去</span><span ttm:role="x-translation" xml:lang="zh-CN">我乘风归去</span></p><p begin="2:51.895" end="2:54.901" itunes:key="L13" ttm:agent="v1"><span begin="2:51.895" end="2:52.150">今</span><span begin="2:52.150" end="2:54.901">夜</span><span ttm:role="x-translation" xml:lang="zh-CN">今夜</span></p><p begin="2:56.058" end="3:00.435" itunes:key="L14" ttm:agent="v1"><span begin="2:56.058" end="2:56.564">歸</span><span begin="2:56.564" end="2:56.795">還</span><span begin="2:56.795" end="2:58.421">於</span><span begin="2:58.969" end="2:59.430">野</span><span begin="2:59.430" end="2:59.970">草</span><span begin="2:59.970" end="3:00.435">地</span><span ttm:role="x-translation" xml:lang="zh-CN">归还于野草地</span></p><p begin="3:08.078" end="3:08.837" itunes:key="L15" ttm:agent="v2"><span begin="3:08.078" end="3:08.251">草</span><span begin="3:08.251" end="3:08.407">原</span><span begin="3:08.407" end="3:08.587">盡</span><span begin="3:08.587" end="3:08.837">頭</span><span ttm:role="x-translation" xml:lang="zh-CN">草原尽头</span></p><p begin="3:09.303" end="3:10.207" itunes:key="L16" ttm:agent="v2"><span begin="3:09.303" end="3:09.518">我</span><span begin="3:09.518" end="3:09.684">兩</span><span begin="3:09.684" end="3:09.850">手</span><span begin="3:09.850" end="3:10.009">空</span><span begin="3:10.009" end="3:10.207">空</span><span ttm:role="x-translation" xml:lang="zh-CN">我两手空空</span></p><p begin="3:12.296" end="3:14.163" itunes:key="L17" ttm:agent="v2"><span begin="3:12.296" end="3:12.448">悲</span><span begin="3:12.448" end="3:12.582">痛</span><span begin="3:12.582" end="3:13.048">時</span><span begin="3:13.048" end="3:13.203">握</span><span begin="3:13.203" end="3:13.319">不</span><span begin="3:13.319" end="3:13.485">住</span><span begin="3:13.485" end="3:13.602">一</span><span begin="3:13.602" end="3:13.764">顆</span><span begin="3:13.764" end="3:13.923">淚</span><span begin="3:13.923" end="3:14.163">滴</span><span ttm:role="x-translation" xml:lang="zh-CN">悲痛时握不住一颗泪滴</span></p><p begin="3:16.090" end="3:17.728" itunes:key="L18" ttm:agent="v2"><span begin="3:16.090" end="3:16.252">我</span><span begin="3:16.252" end="3:16.369">把</span><span begin="3:16.369" end="3:16.500">石</span><span begin="3:16.500" end="3:16.768">頭</span><span begin="3:16.983" end="3:17.181">還</span><span begin="3:17.181" end="3:17.336">給</span><span begin="3:17.336" end="3:17.534">石</span><span begin="3:17.534" end="3:17.728">頭</span><span ttm:role="x-translation" xml:lang="zh-CN">我把石头还给石头</span></p><p begin="3:19.230" end="3:20.243" itunes:key="L19" ttm:agent="v2"><span begin="3:19.230" end="3:19.428">讓</span><span begin="3:19.428" end="3:19.548">勝</span><span begin="3:19.548" end="3:19.714">利</span><span begin="3:19.714" end="3:19.869">的</span><span begin="3:19.869" end="3:20.042">勝</span><span begin="3:20.042" end="3:20.243">利</span><span ttm:role="x-translation" xml:lang="zh-CN">让胜利的胜利</span></p><p begin="3:24.217" end="3:24.687" itunes:key="L20" ttm:agent="v2"><span begin="3:24.217" end="3:24.341">今</span><span begin="3:24.341" end="3:24.687">夜</span><span ttm:role="x-translation" xml:lang="zh-CN">今夜</span></p><p begin="3:25.326" end="3:26.674" itunes:key="L21" ttm:agent="v2"><span begin="3:25.326" end="3:25.523">青</span><span begin="3:25.523" end="3:25.689">稞</span><span begin="3:25.689" end="3:25.841">只</span><span begin="3:25.841" end="3:26.000">屬</span><span begin="3:26.000" end="3:26.116">於</span><span begin="3:26.116" end="3:26.300">她</span><span begin="3:26.300" end="3:26.476">自</span><span begin="3:26.476" end="3:26.674">己</span><span ttm:role="x-translation" xml:lang="zh-CN">青稞只属于她自己</span></p><p begin="3:27.868" end="3:28.511" itunes:key="L22" ttm:agent="v2"><span begin="3:27.868" end="3:28.112">今</span><span begin="3:28.112" end="3:28.511">夜</span><span ttm:role="x-translation" xml:lang="zh-CN">今夜</span></p><p begin="3:28.934" end="3:30.028" itunes:key="L23" ttm:agent="v2"><span begin="3:28.934" end="3:29.107">我</span><span begin="3:29.107" end="3:29.224">不</span><span begin="3:29.224" end="3:29.400">關</span><span begin="3:29.400" end="3:29.573">心</span><span begin="3:29.573" end="3:29.803">人</span><span begin="3:29.803" end="3:30.028">類</span><span ttm:role="x-translation" xml:lang="zh-CN">我不关心人类</span></p><p begin="3:31.902" end="3:32.301" itunes:key="L24" ttm:agent="v2"><span begin="3:31.902" end="3:32.072">今</span><span begin="3:32.072" end="3:32.301">夜</span><span ttm:role="x-translation" xml:lang="zh-CN">今夜</span></p><p begin="3:32.894" end="3:33.978" itunes:key="L25" ttm:agent="v2"><span begin="3:32.894" end="3:33.021">我</span><span begin="3:33.021" end="3:33.124">不</span><span begin="3:33.124" end="3:33.297">關</span><span begin="3:33.297" end="3:33.498">心</span><span begin="3:33.498" end="3:33.717">人</span><span begin="3:33.717" end="3:33.978">類</span><span ttm:role="x-translation" xml:lang="zh-CN">我不关心人类</span></p><p begin="3:35.347" end="3:36.378" itunes:key="L26" ttm:agent="v2"><span begin="3:35.347" end="3:35.555">我</span><span begin="3:35.555" end="3:35.757">只</span><span begin="3:35.757" end="3:36.021">想</span><span begin="3:36.021" end="3:36.378">你</span><span ttm:role="x-translation" xml:lang="zh-CN">我只想你</span></p></div></body></tt>
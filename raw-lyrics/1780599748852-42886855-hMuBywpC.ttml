<tt xmlns="http://www.w3.org/ns/ttml" xmlns:itunes="http://music.apple.com/lyric-ttml-internal" xmlns:ttm="http://www.w3.org/ns/ttml#metadata" xmlns:tts="http://www.w3.org/ns/ttml#styling" xmlns:amll="http://www.example.com/ns/amll" itunes:timing="Word"><head><metadata><ttm:agent type="person" xml:id="v1"/><amll:meta key="musicName" value="The Crying Solo"/><amll:meta key="artists" value="Della"/><amll:meta key="album" value="INVERSE"/><amll:meta key="ncmMusicId" value="461046384"/><amll:meta key="ttmlAuthorGithub" value="42886855"/><amll:meta key="ttmlAuthorGithubLogin" value="ArSrNa"/><iTunesMetadata xmlns="http://music.apple.com/lyric-ttml-internal"><songwriters><songwriter>Della</songwriter><songwriter>青</songwriter></songwriters></iTunesMetadata></metadata></head><body dur="3:26.453"><div begin="19.912" end="3:26.453"><p begin="19.912" end="22.150" itunes:key="L1" ttm:agent="v1"><span begin="19.912" end="20.435">Here</span> <span begin="20.435" end="20.650">I</span> <span begin="20.650" end="21.294">stand,</span> <span begin="21.294" end="21.553">all</span> <span begin="21.553" end="22.150">alone</span><span ttm:role="x-translation" xml:lang="zh-CN">我独立与此</span></p><p begin="22.150" end="25.159" itunes:key="L2" ttm:agent="v1"><span begin="22.150" end="22.460">My</span> <span begin="22.460" end="22.727">love</span> <span begin="22.727" end="22.980">is</span> <span begin="22.980" end="23.261">gone</span> <span begin="23.261" end="23.505">and</span> <span begin="23.505" end="23.756">all</span> <span begin="23.756" end="24.027">he</span> <span begin="24.027" end="24.460">left</span> <span begin="24.460" end="24.681">to</span> <span begin="24.681" end="25.159">me</span><span ttm:role="x-translation" xml:lang="zh-CN">我的爱人早已离去</span></p><p begin="25.159" end="27.868" itunes:key="L3" ttm:agent="v1"><span begin="25.159" end="25.644">Were</span> <span begin="25.644" end="26.588">broken</span> <span begin="26.588" end="27.868">memories</span><span ttm:role="x-translation" xml:lang="zh-CN">留下了只有破碎的记忆</span></p><p begin="27.868" end="31.162" itunes:key="L4" ttm:agent="v1"><span begin="27.868" end="28.439">I</span> <span begin="28.439" end="28.675">can</span> <span begin="28.675" end="29.177">still</span> <span begin="29.177" end="29.415">feel</span> <span begin="29.415" end="29.686">the</span> <span begin="29.686" end="30.193">breeze</span> <span begin="30.193" end="30.401">of</span> <span begin="30.401" end="30.687">his</span> <span begin="30.687" end="31.162">perfume</span><span ttm:role="x-translation" xml:lang="zh-CN">他的香气仍在我身边飘荡</span></p><p begin="31.162" end="33.227" itunes:key="L5" ttm:agent="v1"><span begin="31.162" end="31.455">My</span> <span begin="31.455" end="31.682">nights</span> <span begin="31.682" end="31.943">are</span> <span begin="31.943" end="32.700">endless</span> <span begin="32.700" end="33.227">now</span><span ttm:role="x-translation" xml:lang="zh-CN">长夜漫漫</span></p><p begin="33.227" end="35.114" itunes:key="L6" ttm:agent="v1"><span begin="33.227" end="33.437">That</span> <span begin="33.437" end="33.741">he’s</span> <span begin="33.741" end="34.133">not</span> <span begin="34.133" end="34.387">in</span> <span begin="34.387" end="34.617">my</span> <span begin="34.617" end="35.114">arms</span><span ttm:role="x-translation" xml:lang="zh-CN">我却不能拥他入怀</span></p><p begin="35.114" end="37.001" itunes:key="L7" ttm:agent="v1"><span begin="35.114" end="35.479">Cause</span> <span begin="35.479" end="35.923">after</span> <span begin="35.923" end="37.001">all</span><span ttm:role="x-translation" xml:lang="zh-CN">毕竟</span></p><p begin="37.210" end="39.828" itunes:key="L8" ttm:agent="v1"><span begin="37.210" end="37.737">We’re</span> <span begin="37.737" end="38.398">alone</span> <span begin="38.398" end="38.638">in</span> <span begin="38.638" end="39.102">our</span> <span begin="39.102" end="39.828">lives</span><span ttm:role="x-translation" xml:lang="zh-CN">我们都孤独的生活着</span></p><p begin="39.828" end="43.143" itunes:key="L9" ttm:agent="v1"><span begin="39.828" end="40.418">I</span> <span begin="40.418" end="40.635">must</span> <span begin="40.635" end="41.144">learn</span> <span begin="41.144" end="41.620">to</span> <span begin="41.620" end="42.251">conceal</span> <span begin="42.251" end="42.494">with</span> <span begin="42.494" end="43.143">myself</span><span ttm:role="x-translation" xml:lang="zh-CN">我必须学会隐藏自己</span></p><p begin="43.143" end="45.094" itunes:key="L10" ttm:agent="v1"><span begin="43.143" end="43.485">Can</span> <span begin="43.485" end="43.965">someone</span> <span begin="43.965" end="45.094">fix</span><span ttm:role="x-translation" xml:lang="zh-CN">有人能修复</span></p><p begin="45.094" end="46.891" itunes:key="L11" ttm:agent="v1"><span begin="45.094" end="45.396">My</span> <span begin="45.396" end="45.871">broken</span> <span begin="45.871" end="46.891">heart</span><span ttm:role="x-translation" xml:lang="zh-CN">我破碎的心么</span></p><p begin="47.145" end="55.078" itunes:key="L12" ttm:agent="v1"><span begin="47.145" end="47.396">And</span> <span begin="47.396" end="47.685">help</span> <span begin="47.685" end="47.924">me</span> <span begin="47.924" end="48.616">start</span> <span begin="48.616" end="49.172">life</span> <span begin="49.172" end="49.927">all</span> <span begin="50.040" end="51.752">over</span> <span begin="51.918" end="53.217">now</span> <span begin="53.217" end="53.502">that</span> <span begin="53.502" end="53.719">I</span> <span begin="53.719" end="55.078">care</span><span ttm:role="x-translation" xml:lang="zh-CN">就让我随我想的那样人生重来吧</span></p><p begin="55.078" end="57.192" itunes:key="L13" ttm:agent="v1"><span begin="55.078" end="55.458">I’m</span> <span begin="55.458" end="55.981">crying</span> <span begin="55.981" end="57.192">solo</span><span ttm:role="x-translation" xml:lang="zh-CN">我独自一人哭泣</span></p><p begin="57.192" end="59.197" itunes:key="L14" ttm:agent="v1"><span begin="57.192" end="57.447">Ven</span><span begin="57.447" end="57.708">ting</span> <span begin="57.708" end="57.961">my</span> <span begin="57.961" end="58.694">sor</span><span begin="58.694" end="59.197">row</span><span ttm:role="x-translation" xml:lang="zh-CN">释放内心的悲痛</span></p><p begin="59.197" end="1:03.170" itunes:key="L15" ttm:agent="v1"><span begin="59.197" end="59.453">I’m</span> <span begin="59.453" end="59.979">trying</span> <span begin="59.979" end="1:00.425">to</span> <span begin="1:00.425" end="1:00.641">for</span><span begin="1:00.641" end="1:01.159">get</span> <span begin="1:01.159" end="1:01.412">the</span> <span begin="1:01.412" end="1:01.682">world</span> <span begin="1:01.682" end="1:01.928">that</span> <span begin="1:01.928" end="1:02.188">we</span> <span begin="1:02.188" end="1:02.451">had</span> <span begin="1:02.451" end="1:02.703">a</span><span begin="1:02.703" end="1:03.170">head</span><span ttm:role="x-translation" xml:lang="zh-CN">我试图去遗忘我们的未来</span></p><p begin="1:03.170" end="1:05.137" itunes:key="L16" ttm:agent="v1"><span begin="1:03.170" end="1:03.518">The</span> <span begin="1:03.518" end="1:04.022">hours</span> <span begin="1:04.022" end="1:04.724">don’t</span> <span begin="1:04.724" end="1:05.137">run</span><span ttm:role="x-translation" xml:lang="zh-CN">时间不再流动</span></p><p begin="1:05.137" end="1:07.629" itunes:key="L17" ttm:agent="v1"><span begin="1:05.137" end="1:05.621">When</span> <span begin="1:05.621" end="1:05.902">you’re</span> <span begin="1:05.902" end="1:06.399">sad</span> <span begin="1:06.399" end="1:06.721">and</span> <span begin="1:06.721" end="1:07.629">lonely</span><span ttm:role="x-translation" xml:lang="zh-CN">当你悲伤寂寞的时候</span></p><p begin="1:07.629" end="1:11.092" itunes:key="L18" ttm:agent="v1"><span begin="1:07.629" end="1:07.931">And</span> <span begin="1:07.931" end="1:08.738">gravity</span> <span begin="1:08.738" end="1:08.983">feels</span> <span begin="1:08.983" end="1:09.480">more</span> <span begin="1:09.480" end="1:09.689">and</span> <span begin="1:09.689" end="1:10.126">more</span> <span begin="1:10.126" end="1:10.384">in</span> <span begin="1:10.384" end="1:10.613">my</span> <span begin="1:10.613" end="1:11.092">space</span><span ttm:role="x-translation" xml:lang="zh-CN">压力不断施加在我身上</span></p><p begin="1:11.092" end="1:13.076" itunes:key="L19" ttm:agent="v1"><span begin="1:11.092" end="1:11.464">I’m</span> <span begin="1:11.464" end="1:11.966">crying</span> <span begin="1:11.966" end="1:13.076">solo</span><span ttm:role="x-translation" xml:lang="zh-CN">我独自哭泣</span></p><p begin="1:13.076" end="1:15.173" itunes:key="L20" ttm:agent="v1"><span begin="1:13.076" end="1:13.388">Ven</span><span begin="1:13.388" end="1:13.732">ting</span> <span begin="1:13.732" end="1:14.009">my</span> <span begin="1:14.009" end="1:14.691">sor</span><span begin="1:14.691" end="1:15.173">row</span><span ttm:role="x-translation" xml:lang="zh-CN">发泄内心的悲伤</span></p><p begin="1:15.173" end="1:19.190" itunes:key="L21" ttm:agent="v1"><span begin="1:15.173" end="1:15.454">I’m</span> <span begin="1:15.454" end="1:15.986">trying</span> <span begin="1:15.986" end="1:16.433">to</span> <span begin="1:16.433" end="1:16.689">for</span><span begin="1:16.689" end="1:17.200">get</span> <span begin="1:17.200" end="1:17.482">the</span> <span begin="1:17.482" end="1:17.732">world</span> <span begin="1:17.732" end="1:18.004">that</span> <span begin="1:18.004" end="1:18.222">we</span> <span begin="1:18.222" end="1:18.483">had</span> <span begin="1:18.483" end="1:18.744">a</span><span begin="1:18.744" end="1:19.190">head</span><span ttm:role="x-translation" xml:lang="zh-CN">我努力遗忘我们曾共同走过的时光</span></p><p begin="1:19.190" end="1:21.208" itunes:key="L22" ttm:agent="v1"><span begin="1:19.190" end="1:19.468">The</span> <span begin="1:19.468" end="1:19.696">an</span><span begin="1:19.696" end="1:20.018">swer</span> <span begin="1:20.018" end="1:20.494">to</span> <span begin="1:20.494" end="1:20.749">the</span> <span begin="1:20.749" end="1:21.208">pain</span><span ttm:role="x-translation" xml:lang="zh-CN">直面痛苦的意义</span></p><p begin="1:21.208" end="1:23.632" itunes:key="L23" ttm:agent="v1"><span begin="1:21.208" end="1:21.603">Is</span> <span begin="1:21.603" end="1:21.904">to</span> <span begin="1:21.904" end="1:22.390">let</span> <span begin="1:22.390" end="1:22.668">it</span> <span begin="1:22.668" end="1:23.163">find</span> <span begin="1:23.163" end="1:23.632">you</span><span ttm:role="x-translation" xml:lang="zh-CN">仅为寻找到你</span></p><p begin="1:23.632" end="1:28.316" itunes:key="L24" ttm:agent="v1"><span begin="1:23.632" end="1:23.936">In</span> <span begin="1:23.936" end="1:24.497">order</span> <span begin="1:24.497" end="1:24.758">to</span> <span begin="1:24.758" end="1:24.978">feel</span> <span begin="1:24.978" end="1:25.437">strong</span> <span begin="1:25.437" end="1:25.692">for</span> <span begin="1:25.692" end="1:26.424">whatever</span> <span begin="1:26.424" end="1:26.685">is</span> <span begin="1:26.685" end="1:28.316">coming</span><span ttm:role="x-translation" xml:lang="zh-CN">为了以后无论发生什么都能勇敢面对</span></p><p begin="1:43.896" end="1:46.096" itunes:key="L25" ttm:agent="v1"><span begin="1:43.896" end="1:44.472">Breathe,</span> <span begin="1:44.472" end="1:44.719">go</span> <span begin="1:44.719" end="1:45.141">out,</span> <span begin="1:45.141" end="1:45.414">take</span> <span begin="1:45.414" end="1:45.655">a</span> <span begin="1:45.655" end="1:46.096">walk</span><span ttm:role="x-translation" xml:lang="zh-CN">深呼吸,出去,独自漫步</span></p><p begin="1:46.096" end="1:51.182" itunes:key="L26" ttm:agent="v1"><span begin="1:46.096" end="1:46.357">It&apos;s</span> <span begin="1:46.357" end="1:46.656">time</span> <span begin="1:46.656" end="1:46.964">to</span> <span begin="1:46.964" end="1:47.227">fall</span> <span begin="1:47.227" end="1:47.502">in</span> <span begin="1:47.502" end="1:47.750">love</span> <span begin="1:47.750" end="1:48.018">with</span> <span begin="1:48.018" end="1:48.357">life</span> <span begin="1:48.357" end="1:48.700">and</span> <span begin="1:48.700" end="1:49.190">with</span> <span begin="1:49.190" end="1:49.679">what</span> <span begin="1:49.679" end="1:50.073">I</span> <span begin="1:50.073" end="1:50.688">really</span> <span begin="1:50.688" end="1:51.182">am</span><span ttm:role="x-translation" xml:lang="zh-CN">是时候爱上自己的生活与真实的自我了</span></p><p begin="1:51.182" end="1:53.009" itunes:key="L27" ttm:agent="v1"><span begin="1:51.182" end="1:51.451">Cause</span> <span begin="1:51.451" end="1:51.953">after</span> <span begin="1:51.953" end="1:53.009">all</span><span ttm:role="x-translation" xml:lang="zh-CN">毕竟</span></p><p begin="1:53.248" end="1:55.843" itunes:key="L28" ttm:agent="v1"><span begin="1:53.248" end="1:53.673">We’re</span> <span begin="1:53.673" end="1:54.458">alone</span> <span begin="1:54.458" end="1:54.737">in</span> <span begin="1:54.737" end="1:55.212">our</span> <span begin="1:55.212" end="1:55.843">lives</span><span ttm:role="x-translation" xml:lang="zh-CN">我们都是孤独的</span></p><p begin="1:55.843" end="1:59.174" itunes:key="L29" ttm:agent="v1"><span begin="1:55.843" end="1:56.454">I</span> <span begin="1:56.454" end="1:56.658">must</span> <span begin="1:56.658" end="1:57.179">learn</span> <span begin="1:57.179" end="1:57.633">to</span> <span begin="1:57.633" end="1:58.201">conceal</span> <span begin="1:58.201" end="1:58.468">with</span> <span begin="1:58.468" end="1:59.174">myself</span><span ttm:role="x-translation" xml:lang="zh-CN">我学会了隐藏自己</span></p><p begin="1:59.174" end="2:00.839" itunes:key="L30" ttm:agent="v1"><span begin="1:59.174" end="1:59.462">Can</span> <span begin="1:59.462" end="1:59.979">someone</span> <span begin="1:59.979" end="2:00.839">fix</span><span ttm:role="x-translation" xml:lang="zh-CN">有人能愈合</span></p><p begin="2:01.179" end="2:02.848" itunes:key="L31" ttm:agent="v1"><span begin="2:01.179" end="2:01.356">My</span> <span begin="2:01.356" end="2:01.899">broken</span> <span begin="2:01.899" end="2:02.848">heart</span><span ttm:role="x-translation" xml:lang="zh-CN">我残破的心灵么</span></p><p begin="2:03.145" end="2:11.271" itunes:key="L32" ttm:agent="v1"><span begin="2:03.145" end="2:03.406">And</span> <span begin="2:03.406" end="2:03.687">help</span> <span begin="2:03.687" end="2:03.954">me</span> <span begin="2:03.954" end="2:04.599">start</span> <span begin="2:04.599" end="2:05.121">life</span> <span begin="2:05.121" end="2:05.738">all</span> <span begin="2:05.738" end="2:07.441">over</span> <span begin="2:07.878" end="2:09.190">now</span> <span begin="2:09.190" end="2:09.425">that</span> <span begin="2:09.425" end="2:09.642">I</span> <span begin="2:09.642" end="2:11.271">care</span><span ttm:role="x-translation" xml:lang="zh-CN">那就帮我随我想的那样让我的人生重来吧</span></p><p begin="2:13.213" end="2:15.181" itunes:key="L33" ttm:agent="v1"><span begin="2:13.213" end="2:13.431">I’m</span> <span begin="2:13.431" end="2:13.959">crying</span> <span begin="2:13.959" end="2:15.181">solo</span><span ttm:role="x-translation" xml:lang="zh-CN">我独自哭泣</span></p><p begin="2:15.181" end="2:17.157" itunes:key="L34" ttm:agent="v1"><span begin="2:15.181" end="2:15.441">Ven</span><span begin="2:15.441" end="2:15.696">ting</span> <span begin="2:15.696" end="2:15.968">my</span> <span begin="2:15.968" end="2:16.592">sor</span><span begin="2:16.592" end="2:17.157">row</span><span ttm:role="x-translation" xml:lang="zh-CN">释放内心的伤痛</span></p><p begin="2:17.157" end="2:21.194" itunes:key="L35" ttm:agent="v1"><span begin="2:17.157" end="2:17.430">I’m</span> <span begin="2:17.430" end="2:17.940">trying</span> <span begin="2:17.940" end="2:18.446">to</span> <span begin="2:18.446" end="2:18.683">for</span><span begin="2:18.683" end="2:19.168">get</span> <span begin="2:19.168" end="2:19.428">the</span> <span begin="2:19.428" end="2:19.676">world</span> <span begin="2:19.676" end="2:19.969">that</span> <span begin="2:19.969" end="2:20.225">we</span> <span begin="2:20.225" end="2:20.460">had</span> <span begin="2:20.460" end="2:20.733">a</span><span begin="2:20.733" end="2:21.194">h